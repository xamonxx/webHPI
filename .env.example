# ============================================
# PRODUCTION CONFIGURATION
# Home Putra Interior - Hostinger Deployment
# ============================================
# IMPORTANT:
# 1. Copy this file to .env
# 2. Generate APP_KEY with: php artisan key:generate
# 3. Fill in all values marked with < >
# 4. DO NOT commit .env to version control

APP_NAME="Home Putra Interior"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ============================================
# DATABASE - Hostinger MySQL
# ============================================
# Get these values from Hostinger control panel
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=<your_database_name>
DB_USERNAME=<your_database_user>
DB_PASSWORD=<your_strong_password_here>

# ============================================
# SESSION & CACHE
# ============================================
# Using database driver for multi-server compatibility
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
CACHE_PREFIX=hpi_

# ============================================
# QUEUE & BROADCASTING
# ============================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# ============================================
# MAIL - SMTP Configuration
# ============================================
# Hostinger SMTP settings
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=<your_email@yourdomain.com>
MAIL_PASSWORD=<your_email_password>
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# ASSETS
# ============================================
ASSET_URL=null
