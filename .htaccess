# ------------------------------------------------------------------------------
# 1. SECURITY & PERFORMANCE HEADERS
# ------------------------------------------------------------------------------
<IfModule mod_headers.c>
    # Mencegah website di-iframe oleh situs lain (Clickjacking protection)
    Header set X-Frame-Options "SAMEORIGIN"
    # Mencegah browser menebak jenis file (MIME sniffing)
    Header set X-Content-Type-Options "nosniff"
    # Mengaktifkan proteksi XSS di browser lama
    Header set X-XSS-Protection "1; mode=block"
    # Keamanan referer
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ------------------------------------------------------------------------------
# 2. BLOCK ACCESS TO SENSITIVE FILES
# ------------------------------------------------------------------------------
# Nonaktifkan listing direktori (agar orang tidak bisa melihat isi folder)
Options -Indexes

# Blokir akses ke file sensitif (Dotfiles, env, composer, dll)
# Menggunakan sintaks Apache 2.4 (Require all denied) untuk mencegah Error 500
<FilesMatch "^\.(env|git|svn|DS_Store|Thumbs\.db)">
    Require all denied
</FilesMatch>

<FilesMatch "^\.env\.">
    Require all denied
</FilesMatch>

<FilesMatch "^\.git">
    Require all denied
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|phpunit\.xml\.dist|README\.md|artisan|vite\.config\.js|webpack\.mix\.js|yarn\.lock|tsconfig\.json|\.eslintrc|\.prettierrc)$">
    Require all denied
</FilesMatch>

# Blokir ekstensi file backup/log/config
<FilesMatch "\.(bak|old|sql|log|sh|ini|conf|cfg)$">
    Require all denied
</FilesMatch>

# Blokir file PHP temp / edit files
<FilesMatch "\.(php~|swp|swo|bak)$">
    Require all denied
</FilesMatch>

# Blokir file database & credentials
<FilesMatch "\.(sqlite|db|mdb)$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(key|pem|cert|p12|pfx)$">
    Require all denied
</FilesMatch>

# Blokir htaccess & htpasswd
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# Blokir file IDE/editor
<FilesMatch "\.(vscode|idea)$">
    Require all denied
</FilesMatch>

# Blokir file Lagrange-specific sensitive
<FilesMatch "^lagrange\.(json|env|log)$">
    Require all denied
</FilesMatch>

# Blokir direktori sensitif
<IfModule mod_rewrite.c>
    RewriteRule ^(vendor|node_modules|storage|bootstrap|cache|\.vscode|\.idea) - [F,L]
</IfModule>

# Blokir akses storage folder (kecuali public)
<IfModule mod_rewrite.c>
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^storage/[^/]+/[^/]+/ - [F,L]
</IfModule>

# Blokir akses bootstrap/cache
<IfModule mod_rewrite.c>
    RewriteRule ^(bootstrap|config|database|resources)/ - [F,L]
</IfModule>

# ------------------------------------------------------------------------------
# 3. LARAVEL ROUTING (SHARED HOSTING FIX)
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Paksa HTTPS (Opsional - Hapus tanda pagar jika belum ada auto-ssl dari hosting)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- PENTING: Arahkan traffic ke folder public/ ---
    
    # 1. Jika request mengarah ke folder public/, biarkan apa adanya (hindari loop)
    RewriteRule ^public/ - [L]

    # 2. Jika request adalah file atau folder yang BENAR-BENAR ada di root, layani langsung
    # (Ini penting untuk validasi Google, sitemap.xml di root, dll)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Alihkan semua request lain ke folder public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>